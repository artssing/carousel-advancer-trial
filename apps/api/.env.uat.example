DATABASE_URL="postgresql://authentik:authentik_dev@localhost:5432/authentik_uat?schema=public"
JWT_SECRET="uat-only-change-me-use-32+-chars-random"
JWT_EXPIRES_IN="7d"
API_PORT=4010
CORS_ORIGIN="http://localhost:3018,http://localhost:3011,http://localhost:3013"

# Consumer URL — where Google SSO callback redirects users (login / link-confirm / complete-profile)
NEXT_PUBLIC_CONSUMER_URL="http://localhost:3018"

# Google SSO (Founder ruling 2026-06-11 — P0 Google only).
# Setup: see docs/google-sso-setup.md
# Leave empty to disable Google button — login page still works with email/password.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4010/api/auth/google/callback"

# ── Stripe（UAT = test mode 接本地 mock gateway；上真 Stripe 時換 sk_test 真 key + 刪 STRIPE_API_BASE）──
STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_mock_local
STRIPE_WEBHOOK_SECRET=whsec_mock_local
STRIPE_API_BASE=http://localhost:4252
